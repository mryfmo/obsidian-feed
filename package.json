{
	"name": "Feeds Reader",
	"version": "1.0.0",
	"description": "This is an Obsidian plugin for reading RSS feeds.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-md",
		"obsidian-plugin",
		"rss",
		"feed",
		"reader",
		"atom"
	],
	"author": "mryfmo",
	"license": "GPL-3.0-only",
	"devDependencies": {
		"@types/node": "^18.17.0",
		"@types/pako": "^2.0.3",
		"@typescript-eslint/eslint-plugin": "^7.13.0",
		"@typescript-eslint/parser": "^7.13.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.25.1",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.5"
	},
	"dependencies": {
		"pako": "^2.1.0"
	}
}